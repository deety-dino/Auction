<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@main-style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fxml.auction.MainController" styleClass="main-root">
    <top>
        <VBox spacing="16.0" styleClass="container" BorderPane.alignment="CENTER">
            <VBox styleClass="app-header">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                        <Label styleClass="app-title" text="BakeManage" />
                        <Label styleClass="sub" text="Quan ly nguyen lieu ton kho va toi uu san xuat" />
                    </VBox>
                    <HBox alignment="CENTER" spacing="8.0" styleClass="user-info">
                        <Label text="User:" />
                        <Label fx:id="currentUserLabel" text="guest" />
                        <Button onAction="#onLogoutClick" styleClass="logout-btn" text="Dang xuat" />
                    </HBox>
                </HBox>
            </VBox>

            <HBox spacing="10.0" styleClass="tabs">
                <ToggleButton fx:id="ingredientsTab" onAction="#onIngredientsTabClick" styleClass="tab-btn tab-btn-active" text="Nguyen lieu" />
                <ToggleButton fx:id="recipesTab" onAction="#onRecipesTabClick" styleClass="tab-btn" text="Cong thuc" />
                <ToggleButton fx:id="productionTab" onAction="#onProductionTabClick" styleClass="tab-btn" text="San xuat va Ton kho" />
                <ToggleButton fx:id="profitTab" onAction="#onProfitTabClick" styleClass="tab-btn" text="Bao cao loi nhuan" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="18.0" styleClass="container" BorderPane.alignment="CENTER">
            <VBox spacing="12.0" styleClass="card">
                <Label styleClass="card-title" text="Nhap nguyen lieu moi (ho tro gram/ml, gia le)" />
                <GridPane hgap="15.0" vgap="12.0">
                    <TextField promptText="Ten nguyen lieu" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField promptText="So luong (gram/ml)" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <TextField promptText="Gia tien (VND)" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <ComboBox promptText="Don vi" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                </GridPane>
                <Button maxWidth="200.0" text="Them nguyen lieu" />
            </VBox>

            <VBox spacing="10.0" styleClass="card">
                <Label styleClass="card-title" text="Danh sach nguyen lieu ton kho" />
                <TableView prefHeight="190.0">
                    <columns>
                        <TableColumn prefWidth="220.0" text="Ten" />
                        <TableColumn prefWidth="180.0" text="Ton (g/ml)" />
                        <TableColumn prefWidth="180.0" text="Gia/g (d)" />
                        <TableColumn prefWidth="180.0" text="Thao tac" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10.0" styleClass="card">
                <Label styleClass="card-title" text="Tao / Cap nhat cong thuc san pham" />
                <TextField promptText="Ten san pham" />
                <TextArea prefRowCount="3" promptText='JSON nguyen lieu: {"Bot mi": 50, "Duong": 20, "Bo": 30}' wrapText="true" />
                <Button maxWidth="180.0" text="Luu cong thuc" />
            </VBox>

            <VBox spacing="10.0" styleClass="card">
                <Label styleClass="card-title" text="Bao cao tong hop" />
                <Label styleClass="loading" text="Dang tai..." />
                <Separator />
                <HBox spacing="10.0" styleClass="flex-btns">
                    <Button styleClass="btn-outline" text="Reset du lieu" />
                    <Button styleClass="btn-outline" text="Xoa lich su ban hang" />
                </HBox>
            </VBox>
        </VBox>
    </center>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</BorderPane>


